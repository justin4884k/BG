---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Rest Church is a thriving Christian community worshiping God together in San Antonio, Texas.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const fullTitle = title === 'Home' ? 'Rest Church — San Antonio, TX' : `${title} | Rest Church`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content="website" />
  <meta name="theme-color"        content="#1B2B4B" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
