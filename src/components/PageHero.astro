---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  breadcrumb?: { label: string; href: string }[];
  align?: 'left' | 'center';
  size?: 'sm' | 'md' | 'lg';
  bgImage?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  breadcrumb,
  align = 'center',
  size = 'md',
  bgImage = 'https://brazengrace.org/wp-content/uploads/2020/08/gc4.jpg',
} = Astro.props;
---

<section class:list={['page-hero', `hero-${size}`, `hero-${align}`]}>
  <img src={bgImage} alt="" class="hero-photo-bg" aria-hidden="true" loading="eager" />
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-inner">
      {breadcrumb && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          {breadcrumb.map((crumb) => (
            <>
              <span class="breadcrumb-sep" aria-hidden="true">›</span>
              {crumb.href ? (
                <a href={crumb.href}>{crumb.label}</a>
              ) : (
                <span>{crumb.label}</span>
              )}
            </>
          ))}
        </nav>
      )}
      {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
      <h1 class="hero-title">{title}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      <slot />
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    background: var(--navy-dark);
    color: var(--white);
    overflow: hidden;
    padding-top: var(--header-h);
  }

  .hero-photo-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    opacity: .18;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(201,151,58,.13) 0%, transparent 60%),
      linear-gradient(160deg, rgba(13,26,48,.95) 0%, rgba(27,43,75,.92) 60%, rgba(36,55,88,.93) 100%);
  }

  /* Decorative shapes */
  .hero-bg::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0; right: 0;
    height: 3px;
    background: var(--gold);
    opacity: .35;
  }

  .container { position: relative; z-index: 1; }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  /* Sizes */
  .hero-sm  .hero-inner { padding: 3rem 0 3.25rem; }
  .hero-md  .hero-inner { padding: 4rem 0 4.5rem; }
  .hero-lg  .hero-inner { padding: 5.5rem 0 6rem; }

  /* Alignment */
  .hero-center .hero-inner { align-items: center; text-align: center; }
  .hero-left   .hero-inner { align-items: flex-start; }

  .hero-eyebrow {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.15;
  }

  .hero-subtitle {
    font-size: clamp(.95rem, 2vw, 1.1rem);
    color: rgba(255,255,255,.68);
    max-width: 560px;
    line-height: 1.75;
  }

  .hero-center .hero-subtitle { max-width: 600px; }
</style>
